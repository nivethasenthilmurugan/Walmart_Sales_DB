SELECT SUM(Total) AS TotalSales
FROM Walmart_Sales;

SELECT COUNT(*) AS TotalOrders
FROM Walmart_Sales;

SELECT AVG(Total) AS AverageOrderValue
FROM Walmart_Sales;

SELECT
Branch,
SUM(Total) AS TotalSales
FROM Walmart_Sales
GROUP BY Branch
ORDER BY TotalSales DESC;

SELECT
City,
SUM(Total) AS TotalSales
FROM Walmart_Sales
GROUP BY City
ORDER BY TotalSales DESC;

SELECT
Branch,
SUM(GrossIncome) AS Profit
FROM Walmart_Sales
GROUP BY Branch
ORDER BY Profit DESC;

SELECT top 1 Branch,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY Branch
ORDER BY Sales DESC;


SELECT TOP 1
Branch,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY Branch
ORDER BY Sales DESC;

SELECT
MONTH(Date) AS Month,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY MONTH(Date)
ORDER BY Month;

SELECT
MONTH(Date) AS Month,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY MONTH(Date)
ORDER BY Month;

SELECT
Date,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY Date
ORDER BY Date;

SELECT
DATENAME(WEEKDAY, Date) AS DayName,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY DATENAME(WEEKDAY, Date);

SELECT
Gender,
COUNT(*) AS Customers
FROM Walmart_Sales
GROUP BY Gender;

SELECT
CustomerType,
COUNT(*) AS TotalCustomers
FROM Walmart_Sales
GROUP BY CustomerType;

SELECT
CustomerType,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY CustomerType;

SELECT
AVG(Rating) AS AverageRating
FROM Walmart_Sales;

SELECT
Branch,
AVG(Rating) AS AvgRating
FROM Walmart_Sales
GROUP BY Branch;

SELECT
ProductLine,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY ProductLine
ORDER BY Sales DESC;

SELECT
ProductLine,
SUM(Quantity) AS QuantitySold
FROM Walmart_Sales
GROUP BY ProductLine;

SELECT
ProductLine,
AVG(UnitPrice) AS AveragePrice
FROM Walmart_Sales
GROUP BY ProductLine;

SELECT
ProductLine,
SUM(GrossIncome) AS Profit
FROM Walmart_Sales
GROUP BY ProductLine
ORDER BY Profit DESC;

SELECT top 1
ProductLine,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY ProductLine
ORDER BY Sales DESC;

SELECT TOP 1
ProductLine,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY ProductLine
ORDER BY Sales DESC;

SELECT TOP 10 *
FROM Walmart_Sales
ORDER BY Total DESC;

SELECT
Date,
Total,
SUM(Total) OVER(ORDER BY Date) AS RunningTotal
FROM Walmart_Sales;

SELECT
Branch,
SUM(Total) AS Sales,
DENSE_RANK() OVER(ORDER BY SUM(Total) DESC) AS BranchRank
FROM Walmart_Sales
GROUP BY Branch;

SELECT TOP 1
Date,
SUM(Total) AS Sales
FROM Walmart_Sales
GROUP BY Date
ORDER BY Sales DESC;

SELECT TOP 1
ProductLine,
AVG(Rating) AS AvgRating
FROM Walmart_Sales
GROUP BY ProductLine
ORDER BY AvgRating DESC;

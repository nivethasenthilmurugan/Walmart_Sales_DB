create database Walmart_Sales_DB;
USE Walmart_Sales_DB;


CREATE TABLE Walmart_Sales (
    InvoiceID VARCHAR(20) PRIMARY KEY,
    Branch VARCHAR(5),
    City VARCHAR(30),
    CustomerType VARCHAR(20),
    Gender VARCHAR(10),
    ProductLine VARCHAR(100),
    UnitPrice DECIMAL(10,2),
    Quantity INT,
    Tax DECIMAL(10,2),
    Total DECIMAL(10,2),
    Date DATE,
    Time TIME,
    Payment VARCHAR(20),
    COGS DECIMAL(10,2),
    GrossMarginPercentage DECIMAL(10,2),
    GrossIncome DECIMAL(10,2),
    Rating DECIMAL(3,1)
);


